# WOOK'S CODING 환경변수 예시 - 복사해서 .env 로 사용
# cp .env.example .env

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (문서 규칙: DB는 PostgreSQL 고정)
POSTGRES_DB=wooks_coding
POSTGRES_USER=wooks
POSTGRES_PASSWORD=password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# 내부 통신 (Django <-> FastAPI)
INTERNAL_API_KEY=dev-internal-key

# FastAPI / AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ChromaDB (벡터 인덱스)
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000
CHROMA_COLLECTION=wrong_note_embeddings

# RAG 기본값 (지시문 확정 기준)
RAG_SCORE_THRESHOLD=0.35
TOP_K=5

# Worker (코드 실행) — 샌드박스 제한값
CODE_TIMEOUT_SEC=5            # 실행 제한시간(초). RLIMIT_CPU 도 이 값 기준
CODE_MEM_LIMIT_MB=256        # 코드 1회 실행 메모리 상한(MB, RLIMIT_AS)
CODE_DISABLE_NETWORK=true    # 코드 실행 네트워크 차단(unshare 네트워크 네임스페이스)
WORKER_POLL_INTERVAL_SEC=2

# 로깅 (개발/디버깅/AI연구용)
LOG_LEVEL=INFO
# LOG_DIR 비우면 각 컴포넌트가 <repo루트>/logs 사용. Docker 는 compose 가 /app/logs 주입.
LOG_DIR=
