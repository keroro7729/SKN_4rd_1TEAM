# WOOK'S CODING 환경변수 예시 - 복사해서 .env 로 사용
#   cp .env.example .env
#
# 한 개의 .env 를 모든 컴포넌트가 공유한다.
# 환경별 실행은 compose/ 의 파일을 골라 쓴다 (compose/README.md 참고):
#   - 개발/테스트 : compose/local.yml  (postgres 컨테이너 포함, 올인원)
#   - 운영 앱서버  : compose/main.yml   (RDS 사용, worker 제외)
#   - 운영 워커    : compose/worker.yml (RDS 사용, worker 만)
#
# 아래 각 항목의 [운영] 주석 = 실제 운영(main/worker + RDS)에서 반드시 바꿔야 할 값.

# ─────────────────────────────────────────────
# Django
# ─────────────────────────────────────────────
# [운영] 반드시 새로 생성한 긴 랜덤 문자열로 교체 (예: python -c "import secrets;print(secrets.token_urlsafe(64))")
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# [운영] 반드시 False (True 면 트레이스백/설정이 외부에 노출됨)
DJANGO_DEBUG=True
# [운영] 실제 접속 도메인/EIP 를 콤마로. (localhost,127.0.0.1 및 코드 기본 호스트는 자동 포함)
#   예) DJANGO_ALLOWED_HOSTS=wooks.example.com,3.36.123.126
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────
# PostgreSQL  (문서 규칙: DB는 PostgreSQL 고정)
#   개발 : compose/local.yml 의 postgres 컨테이너 (HOST=postgres 는 compose 가 주입)
#   운영 : 외부 RDS. 앱서버·워커 EC2 모두 아래 값을 RDS 로 맞춘다.
# ─────────────────────────────────────────────
POSTGRES_DB=wooks_coding
POSTGRES_USER=wooks
# [운영] RDS 마스터 비밀번호 (강한 값)
POSTGRES_PASSWORD=password
# [운영] RDS 엔드포인트로 교체. 예) wooks-prod.abcdefg.ap-northeast-2.rds.amazonaws.com
#   (local.yml 은 compose 가 'postgres' 로 덮어쓰므로 로컬에선 이 값 무시됨)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# ─────────────────────────────────────────────
# 내부 통신 (Django <-> FastAPI)
# ─────────────────────────────────────────────
# [운영] 강한 랜덤 키로 교체. Django·FastAPI 가 같은 값을 가져야 한다 (불일치 시 401).
INTERNAL_API_KEY=dev-internal-key
# Django 가 호출할 FastAPI 주소 (docker 네트워크 기본값). 보통 변경 불필요.
FASTAPI_BASE_URL=http://fastapi:8001
INTERNAL_API_TIMEOUT_SEC=20

# ─────────────────────────────────────────────
# FastAPI / AI
# ─────────────────────────────────────────────
# [운영] 실제 OpenAI API 키 필수 (비우면 힌트/오답분석/임베딩이 해시 폴백으로 저품질 동작)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# RAG 임베딩(리트리빙 v1). auto=키 있으면 openai, 없으면 결정적 해시 폴백.
EMBED_MODEL=text-embedding-3-small
RAG_EMBED_BACKEND=auto

# ─────────────────────────────────────────────
# ChromaDB (벡터 인덱스)  — 컬렉션은 임베더별 자동 버저닝(wrong_note_embeddings-<sig>)
#   HOST 는 compose 가 'chromadb' 로 주입 → 보통 변경 불필요
# ─────────────────────────────────────────────
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000
CHROMA_COLLECTION=wrong_note_embeddings

# ─────────────────────────────────────────────
# RAG 기본값 (지시문 확정 기준 + v1 섹션 청킹/집계)
# ─────────────────────────────────────────────
RAG_SCORE_THRESHOLD=0.35
TOP_K=5
RAG_CHUNK_MAX_CHARS=160   # 섹션 청크 최대 길이(짧은 청크 매칭)
RAG_PER_QUERY_K=12        # 쿼리 청크당 후보 청크 수
RAG_W_MEAN=0.5            # 섹션 유사도 평균 가중
RAG_W_MAX=0.5             # 섹션 유사도 최댓값 가중

# ─────────────────────────────────────────────
# Worker (코드 실행) — 샌드박스 제한값 (운영 워커 EC2 에서도 동일 .env 사용)
# ─────────────────────────────────────────────
CODE_TIMEOUT_SEC=5           # 실행 제한시간(초). RLIMIT_CPU 도 이 값 기준
CODE_MEM_LIMIT_MB=256        # 코드 1회 실행 메모리 상한(MB, RLIMIT_AS)
CODE_DISABLE_NETWORK=true    # 코드 실행 네트워크 차단(unshare 네트워크 네임스페이스)
WORKER_POLL_INTERVAL_SEC=2

# ─────────────────────────────────────────────
# 로깅 (개발/디버깅/AI연구용)
# ─────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_DIR 비우면 각 컴포넌트가 <repo루트>/logs 사용. Docker 는 compose 가 /logs 주입.
LOG_DIR=
